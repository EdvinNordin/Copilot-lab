{
  "name": "daily-harvest-api",
  "private": true,
  "version": "0.0.0",
  "description": "The Daily Harvest - Backend REST API",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
